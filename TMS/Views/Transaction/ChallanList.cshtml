@{
    ViewBag.Title = "Challan Register";
}

<div class="row">
    <div class="col-12">
        <div class="card">

            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Challan Register</h4>
                <a href="/Transaction/ChallanEntry" id="btnCreateNewChallan" class="btn btn-primary btn-sm">
                    <i class="fa fa-plus"></i> Create New Challan
                </a>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table id="challanListTable" class="display table-hover table-striped w-100">
                        <thead class="table-primary text-center">
                            <tr>
                                <th style="width:10%;">Voucher No</th>
                                <th style="width:10%;">Date</th>
                                <th style="width:15%;">Truck No</th>
                                <th style="width:20%;">Consignee</th>
                                <th style="width:15%;">Driver Name</th>
                                <th style="width:15%;">Final Amount</th>
                                <th style="width:10%;">Entry By</th>
                                <th style="width:5%;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="tblBody">
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/TMSJs/Transaction/ChallanList.js"></script>
}