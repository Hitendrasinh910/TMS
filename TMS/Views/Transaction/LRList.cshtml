@{
    ViewBag.Title = "LR Register";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Lorry Receipt (LR) Register</h4>
                <a href="/Transaction/LREntry" id="btnCreateNewLR" class="btn btn-primary btn-sm">
                    <i class="fa fa-plus"></i> Create New LR
                </a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="lrListTable" class="display table-hover table-striped w-100">
                        <thead class="table-primary">
                            <tr>
                                <th>LR No</th>
                                <th>LR Date</th>
                                <th>Consignor</th>
                                <th>Consignee</th>
                                <th>Total Amt</th>
                                <th>Entry By</th>
                                <th style="width:5%; text-align:center;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="tblBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/TMSJs/Transaction/LRList.js" asp-append-version="true"></script>
}