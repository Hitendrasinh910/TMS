@{
    ViewBag.Title = "Bill Details";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="card-title mb-0">Bill Details</h4>
                <div>
                    <button class="btn btn-primary" id="btnSave"><i class="fa fa-save"></i> Save / Update</button>
                    <a href="/Transaction/BillList" class="btn btn-danger"><i class="fa fa-times"></i> Close</a>
                </div>
            </div>

            <div class="card-body">
                <form id="billForm" autocomplete="off">
                    <input type="hidden" id="hdnId" value="0" />

                    <div class="row g-3 mb-4 bg-light p-3 rounded border">
                        <div class="col-md-3">
                            <label class="form-label">Bill No</label>
                            <input type="text" class="form-control" id="txtBillNo" readonly placeholder="Auto Generated">
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtBillDate" required>
                        </div>

                        <div class="col-md-3"></div> <div class="col-md-6">
                            <label class="form-label">Bill To Party <span class="text-danger">*</span></label>
                            <select class="form-control form-select" id="ddlParty" required></select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Truck No</label>
                            <select class="form-control form-select" id="ddlTruck"></select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Driver Mobile No</label>
                            <input type="text" class="form-control" id="txtMobile" placeholder="Mobile No">
                        </div>
                    </div>

                    <h5 class="mb-2 border-bottom pb-2">Details</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered table-sm" id="tblItems">
                            <thead class="table-primary text-center align-middle">
                                <tr>
                                    <th style="width: 10%">LR No</th>
                                    <th style="width: 10%">LR Date</th>
                                    <th style="width: 15%">Description</th>
                                    <th style="width: 10%">From</th>
                                    <th style="width: 10%">Destination</th>
                                    <th style="width: 8%">Freight On</th>
                                    <th style="width: 7%">Fix</th>
                                    <th style="width: 7%">Weight</th>
                                    <th style="width: 7%">Rate</th>
                                    <th style="width: 8%">Extra Chg</th>
                                    <th style="width: 8%">Amount</th>
                                    <th style="width: 5%">Action</th>
                                </tr>
                            </thead>
                            <tbody id="gridBody">
                            </tbody>
                            <tfoot class="bg-light">
                                <tr>
                                    <td>
                                        <select class="form-control form-select form-select-sm" id="inLR">
                                            <option value="">-- LR No --</option>
                                        </select>
                                    </td>
                                    <td><input type="date" class="form-control form-control-sm" id="inLRDate" readonly></td>
                                    <td><input type="text" class="form-control form-control-sm" id="inDesc"></td>
                                    <td>
                                        <select class="form-control form-select form-select-sm" id="inFrom">
                                            <option value="">-- City --</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select class="form-control form-select form-select-sm" id="inTo">
                                            <option value="">-- City --</option>
                                        </select>
                                    </td>
                                    <td>
                                        <select class="form-control form-select form-select-sm calc-trigger" id="inFreightOn">
                                            <option value="Fix">Fix</option>
                                            <option value="Weight">Weight</option>
                                        </select>
                                    </td>
                                    <td><input type="number" class="form-control form-control-sm text-end calc-trigger" id="inFix" value="0.00"></td>
                                    <td><input type="number" class="form-control form-control-sm text-end calc-trigger" id="inWeight" value="0.00"></td>
                                    <td><input type="number" class="form-control form-control-sm text-end calc-trigger" id="inRate" value="0.00"></td>
                                    <td><input type="number" class="form-control form-control-sm text-end calc-trigger" id="inExtra" value="0.00"></td>
                                    <td><input type="number" class="form-control form-control-sm text-end bg-white fw-bold" id="inAmount" readonly value="0.00"></td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-success btn-sm" id="btnAddItem"><i class="fa fa-plus"></i></button>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>

                    <div class="row g-3 mt-4 border-top pt-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Remarks :</label>
                            <textarea class="form-control" id="txtRemarks" rows="4" placeholder="Enter any additional remarks..."></textarea>
                        </div>
                        <div class="col-md-4">
                            <table class="table table-borderless table-sm">
                                <tbody>
                                    <tr>
                                        <td class="text-end align-middle fw-bold w-50 fs-5 text-secondary">Final Amount :</td>
                                        <td>
                                            <input type="number" class="form-control text-end bg-light fw-bold text-primary fs-5" id="txtFinal" readonly value="0.00">
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-end align-middle fw-bold text-secondary">To Pay Amount :</td>
                                        <td>
                                            <input type="number" class="form-control text-end calc-total" id="txtToPay" value="0.00">
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="text-end align-middle fw-bold text-secondary">Commission :</td>
                                        <td>
                                            <input type="number" class="form-control text-end calc-total" id="txtCommission" value="0.00">
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/TMSJs/Transaction/BillEntry.js" asp-append-version="true"></script>
}