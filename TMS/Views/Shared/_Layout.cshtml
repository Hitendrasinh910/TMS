@using System.Text.Json
@using System.Security.Claims
@using DRSPortal.Models

@{
    // 1. Safely extract the JSON string from the user's claims
    var permissionsClaim = User.FindFirst("UserPermissions")?.Value;
    var userRights = new List<UserRights>();

    if (!string.IsNullOrEmpty(permissionsClaim))
    {
        try
        {
            userRights = JsonSerializer.Deserialize<List<UserRights>>(permissionsClaim);
        }
        catch
        {
            // Fallback to empty list if JSON parsing fails
            userRights = new List<UserRights>();
        }
    }

    // 2. Create a local C# function to easily check rights inside HTML
    bool HasRight(string formName, string actionType)
    {
        var right = userRights.FirstOrDefault(r =>
            r.FormName.Equals(formName, StringComparison.OrdinalIgnoreCase));

        if (right == null) return false;

        return actionType.ToUpper() switch
        {
            "VIEW" => right.AllowToView,
            "ADD" => right.AllowToAdd,
            "UPDATE" => right.AllowToUpdate,
            "DELETE" => right.AllowToDelete,
            _ => false
        };
    }
}

