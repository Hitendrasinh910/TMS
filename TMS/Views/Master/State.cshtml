@{
    ViewBag.Title = "State Master";
}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">State Master</h4>
                <a data-bs-toggle="modal" data-bs-target="#addModal" id="btnCreateNewSate" class="btn btn-primary btn-sm">Add State</a>
            </div>
            <div class="table-responsive">
                <table id="stateList" class="display table-hover table-striped w-100">
                    <thead class="table-primary">
                        <tr>
                            <th>State Name</th>
                            <th>Country</th>
                            <th>Entry Date</th>
                            <th style="width:2%;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="addModalLabel">Add New State</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="entryForm" autocomplete="off">
                    <input type="hidden" id="hdnId" value="0" />
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label">Select Country <span class="text-danger">*</span></label>
                            <select class="form-control form-select" id="ddlCountry" required>
                                <option value="">-- Select Country --</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">State Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtStateName" placeholder="Enter State Name" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btnSave">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/TMSJs/Master/state.js" asp-append-version="true"></script>
}