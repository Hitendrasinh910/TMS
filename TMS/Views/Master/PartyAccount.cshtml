@{
    ViewBag.Title = "Party Account Master";
}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Party Account Master</h4>
                <a data-bs-toggle="modal" data-bs-target="#addModal" id="btnCreateNewPartyAccount" class="btn btn-primary btn-sm">Add Party Account</a>
            </div>
            <div class="table-responsive">
                <table id="partyAccountList" class="display table-hover table-striped w-100">
                    <thead class="table-primary">
                        <tr>
                            <th>Party Code</th>
                            <th>Party Name</th>
                            <th>Contact No</th>
                            <th>City</th>
                            <th>Balance</th>
                            <th style="width:2%;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="addModalLabel">Add New Party Account</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="entryForm" autocomplete="off">
                    <input type="hidden" id="hdnId" value="0" />
                    
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Account Sr No</label>
                            <input type="text" class="form-control" id="txtAccountSrNo" placeholder="Sr No" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Party Code</label>
                            <input type="text" class="form-control" id="txtPartyCode" placeholder="Code">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Account Type</label>
                            <select class="form-control form-select" id="ddlAccountType">
                                <option value="">-- Select Type --</option>
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Party Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtPartyName" placeholder="Enter Party Name" required>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Address</label>
                            <textarea class="form-control" id="txtAddress" rows="2" placeholder="Enter Address"></textarea>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">State</label>
                            <select class="form-control form-select" id="ddlState">
                                <option value="">-- Select State --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">City</label>
                            <select class="form-control form-select" id="ddlCity">
                                <option value="">-- Select City --</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Contact No 1 <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtContactNo1" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Contact No 2</label>
                            <input type="text" class="form-control" id="txtContactNo2">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" id="txtEmail">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">GST No</label>
                            <input type="text" class="form-control" id="txtGSTNo">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">PAN No</label>
                            <input type="text" class="form-control" id="txtPanNo">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Opening Balance</label>
                            <input type="number" step="0.01" class="form-control" id="txtOpeningBalance" value="0.00">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Balance Type</label>
                            <select class="form-control form-select" id="ddlBalanceType">
                                <option value="">-- Select Balance Type --</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btnSave">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/TMSJs/Master/partyAccount.js" asp-append-version="true"></script>
}