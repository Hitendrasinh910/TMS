@{ ViewBag.Title = "Bill To Party Master"; }
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title">Bill To Party Master</h4>
                <a data-bs-toggle="modal" data-bs-target="#addModal" class="btn btn-primary btn-sm">Add New Mapping</a>
            </div>
            <div class="table-responsive">
                <table id="billToList" class="display table-hover table-striped w-100">
                    <thead class="table-primary">
                        <tr>
                            <th>Sr No</th>
                            <th>Consignor</th>
                            <th>Consignee</th>
                            <th>Bill To</th>
                            <th style="width:2%;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="tblBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Add / Edit Bill To Party</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="entryForm" autocomplete="off">
                    <input type="hidden" id="hdnId" value="0" />
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Sr No</label>
                            <input type="number" class="form-control" id="txtSrNo">
                        </div>
                        <div class="col-md-9"></div>

                        <div class="col-md-12">
                            <label class="form-label">Consignor <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlConsignor" required>
                                <option value="">-- Select Consignor --</option>
                            </select>
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label">Consignee <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlConsignee" required>
                                <option value="">-- Select Consignee --</option>
                            </select>
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label">Bill To <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlBillTo" required>
                                <option value="">-- Select Bill To Party --</option>
                            </select>
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label">Remarks</label>
                            <textarea class="form-control" id="txtRemarks" rows="2"></textarea>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary" id="btnSave">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts { <script src="~/TMSJs/Master/billToParty.js" asp-append-version="true"></script> }